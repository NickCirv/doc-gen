{
  "name": "doc-gen",
  "version": "1.0.0",
  "description": "Auto-generate docs from any codebase — README, API reference, directory tree, changelog",
  "type": "module",
  "bin": {
    "doc-gen": "./bin/gen.js"
  },
  "scripts": {
    "start": "node bin/gen.js",
    "test": "node --test src/*.test.js 2>/dev/null || echo 'no tests yet'"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "documentation",
    "generator",
    "readme",
    "api-docs",
    "cli",
    "developer-tools"
  ],
  "author": "NickCirv <nick@cirvgreen.com>",
  "license": "MIT"
}
